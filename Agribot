def predict_single_image(image_path: str):
    """
    Training শেষে যেকোনো ছবি দিয়ে test করার জন্য।
    
    ব্যবহার:
        predict_single_image("/path/to/your/tomato_photo.jpg")
    """
    if not Config.CLASS_MAPPING_PATH.exists():
