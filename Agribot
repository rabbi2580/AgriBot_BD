def advanced_search(farmer_question, top_k=3):
    """
    Sentence-BERT ব্যবহার করে semantic search করো

    Returns top 3 candidates with scores
    """

    # Encode farmer এর প্রশ্ন এবং নিশ্চিত করো এটি সঠিক ডিভাইসে আছে
